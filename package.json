{
  "name": "antigravity-pilot",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "description": "Mobile-first PWA for remotely monitoring & controlling Antigravity IDE sessions",
  "scripts": {
    "predev": "pnpm --filter @ag/shared build",
    "dev": "run-p dev:server dev:web",
    "dev:server": "pnpm --filter @ag/server dev",
    "dev:web": "pnpm --filter @ag/web dev",
    "build": "pnpm --filter @ag/shared build && pnpm --filter @ag/web build && pnpm --filter @ag/server build",
    "test": "pnpm build && node --test --experimental-test-coverage --test-coverage-lines=80 --test-coverage-functions=80 --test-coverage-branches=80 tests/workspaceId.test.js",
    "start": "node packages/server/dist/index.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "web-push": "^3.6.7",
    "ws": "^8.18.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "esbuild"
    ],
    "onlyBuiltDependencies": [
      "react-grab"
    ]
  },
  "devDependencies": {
    "npm-run-all2": "^8.0.4"
  }
}
